{
  "name": "folioman-frontend",
  "version": "1.0.0",
  "private": true,
  "license": "AGPL-3.0-or-later",
  "type": "module",
  "description": "Folioman Vue 3 SPA — shared bundle for desktop and hosted.",
  "engines": {
    "node": ">=24 <25"
  },
  "packageManager": "pnpm@11.5.2",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --build && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "type-check": "vue-tsc --build",
    "generate-pwa-assets": "pwa-assets-generator",
    "gen:api": "openapi-typescript ../openapi.json --output src/api/schema.d.ts"
  },
  "dependencies": {
    "@fontsource/ibm-plex-mono": "^5.2.7",
    "@fontsource/ibm-plex-sans": "^5.2.8",
    "@primeuix/themes": "^2.0.3",
    "echarts": "^6.1.0",
    "openapi-fetch": "^0.17.0",
    "pinia": "^3",
    "primeicons": "^7.0.0",
    "primevue": "^4.2.5",
    "vue": "^3.5.13",
    "vue-echarts": "^8.0.1",
    "vue-router": "^5",
    "workbox-window": "^7.3.0"
  },
  "devDependencies": {
    "@types/node": "^25",
    "@vite-pwa/assets-generator": "^1.0.0",
    "@vitejs/plugin-vue": "^6",
    "@vue/test-utils": "^2.4.11",
    "jsdom": "^29",
    "openapi-typescript": "^7.4.4",
    "typescript": "~6.0.3",
    "vite": "^8",
    "vite-plugin-compression2": "^2.5.3",
    "vite-plugin-pwa": "^1.0.0",
    "vitest": "^4",
    "vue-tsc": "^3"
  }
}
