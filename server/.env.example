# Copy to server/.env and fill in real values before `docker compose up`.
# server/.env is git-ignored; never commit real secrets.

# Django secret key (signs JWTs in server mode). Generate:
#   python -c "import secrets; print(secrets.token_urlsafe(64))"
FOLIOMAN_SECRET_KEY=

# PAN-at-rest encryption key. Generate:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Back this up — without it, encrypted PANs are unrecoverable.
FOLIOMAN_FERNET_KEY=

# Postgres password (used by both the app and the db service).
FOLIOMAN_DB_PASSWORD=

# Hostnames the browser uses to reach the app (comma-separated).
FOLIOMAN_ALLOWED_HOSTS=localhost,127.0.0.1

# Domain for the optional Caddy HTTPS proxy (deploy/hosted/). Also add it to
# FOLIOMAN_ALLOWED_HOSTS above. Only needed for the TLS override.
# FOLIOMAN_DOMAIN=folioman.example.com

# Hosted public demo: set to 1 to run read-only (every write is refused with 403,
# server-side). Pair it with `django-admin seed_demo` to load sample data.
# FOLIOMAN_DEMO=0

# Optional overrides (sensible defaults shown):
# FOLIOMAN_DB_NAME=folioman
# FOLIOMAN_DB_USER=folioman
# FOLIOMAN_PORT=8000
